{
  "_meta": {
    "name": {
      "zh": "平台差异示例",
      "en": "Platform Split Example"
    },
    "author": "zapcmd-team",
    "version": "1.0.0"
  },
  "commands": [
    {
      "id": "query-port-netstat",
      "name": {
        "zh": "查询端口占用（Windows）",
        "en": "Query Port (Windows)"
      },
      "tags": ["port", "端口", "query"],
      "category": "network",
      "platform": "win",
      "script": {
        "runner": "powershell",
        "command": "netstat -ano | findstr :{{port}}"
      },
      "adminRequired": false,
      "args": [
        {
          "key": "port",
          "label": {
            "zh": "端口号",
            "en": "Port"
          },
          "type": "number",
          "required": true
        }
      ],
      "prerequisites": [
        {
          "id": "powershell",
          "type": "shell",
          "required": true,
          "check": "shell:powershell",
          "displayName": {
            "zh": "PowerShell 7",
            "en": "PowerShell 7"
          },
          "resolutionHint": {
            "zh": "安装 PowerShell 7 后重试",
            "en": "Install PowerShell 7 and retry"
          },
          "installHint": {
            "zh": "兼容旧字段示例",
            "en": "Legacy compatibility example"
          },
          "fallbackCommandId": "install-pwsh"
        }
      ]
    },
    {
      "id": "query-port-lsof",
      "name": {
        "zh": "查询端口占用（mac/linux）",
        "en": "Query Port (mac/linux)"
      },
      "tags": ["port", "端口", "query"],
      "category": "network",
      "platform": "mac",
      "exec": {
        "program": "lsof",
        "args": ["-i", ":{{port}}"]
      },
      "adminRequired": false,
      "args": [
        {
          "key": "port",
          "label": {
            "zh": "端口号",
            "en": "Port"
          },
          "type": "number",
          "required": true
        }
      ]
    }
  ]
}
