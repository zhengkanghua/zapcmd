{
  "name": "zapcmd",
  "version": "1.0.1",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.7.0",
  "scripts": {
    "dev": "vite --configLoader native",
    "build": "vue-tsc --noEmit && vite build --configLoader native",
    "preview": "vite preview --configLoader native",
    "version:sync": "node scripts/sync-version.mjs",
    "keys:sync": "node scripts/sync-keys.mjs",
    "prepare": "node scripts/setup-githooks.mjs",
    "tauri:dev": "npm run version:sync && npm run keys:sync && tauri dev",
    "tauri:build:debug": "npm run version:sync && npm run keys:sync && tauri build --debug --no-bundle",
    "tauri:build": "npm run version:sync && npm run keys:sync && tauri build --bundles msi",
    "tauri:build:all": "npm run version:sync && npm run keys:sync && tauri build",
    "e2e:desktop:smoke": "npm run version:sync && npm run keys:sync && npm run build && tauri build --debug --no-bundle --config scripts/e2e/tauri.debug-skip-before-build.json && node scripts/e2e/desktop-smoke.cjs",
    "verify:local": "node scripts/verify-local-gate.mjs",
    "check:rust": "cargo check --manifest-path src-tauri/Cargo.toml",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml",
    "lint": "eslint src vite.config.js vitest.config.js --ext .ts,.vue,.js --max-warnings=0",
    "lint:fix": "eslint src vite.config.js vitest.config.js --ext .ts,.vue,.js --fix",
    "check:all": "npm run version:sync && npm run lint && npm run typecheck && npm run check:style-guard && npm run typecheck:test && npm run test:coverage && npm run build && npm run check:rust && npm run test:rust",
    "precommit:guard": "node scripts/precommit-guard.mjs",
    "typecheck": "vue-tsc --noEmit",
    "typecheck:test": "vue-tsc --noEmit -p tsconfig.test.json",
    "check:style-guard": "node scripts/style-guard.mjs",
    "test": "node -r ./scripts/vitest/patch-vite-net-use.cjs ./node_modules/vitest/vitest.mjs --configLoader runner --config vitest.config.js",
    "test:related": "node -r ./scripts/vitest/patch-vite-net-use.cjs ./node_modules/vitest/vitest.mjs related --run --configLoader runner --config vitest.config.js",
    "test:run": "node -r ./scripts/vitest/patch-vite-net-use.cjs ./node_modules/vitest/vitest.mjs run --configLoader runner --config vitest.config.js",
    "test:coverage": "node scripts/coverage/run-test-coverage.mjs",
    "test:flow:launcher": "npm test -- src/components/launcher/__tests__/LauncherWindow.flow.test.ts",
    "test:flow:settings": "npm test -- src/components/settings/__tests__/SettingsWindow.layout.test.ts",
    "test:contract:styles": "npm run test:run -- src/styles/__tests__/launcher-style-contract.test.ts src/styles/__tests__/tailwind-theme-layer-contract.test.ts src/styles/__tests__/tailwind-governance-contract.test.ts src/__tests__/settings.topbar-nav-style-contract.test.ts",
    "commands:schema:generate": "node scripts/commands/generate-command-schema-validator.mjs",
    "commands:schema:check": "node scripts/commands/check-command-schema-sync.mjs",
    "test:visual:ui": "node scripts/e2e/visual-regression.cjs",
    "test:visual:ui:update": "node scripts/e2e/visual-regression.cjs --update",
    "test:visual:ui:runner": "node scripts/e2e/visual-regression.cjs --mode=controlled-runner",
    "test:visual:ui:update:runner": "node scripts/e2e/visual-regression.cjs --mode=controlled-runner --update",
    "test:visual:ui:wsl-bridge": "node scripts/e2e/visual-regression.cjs --mode=wsl-windows-edge",
    "test:visual:ui:update:wsl-bridge": "node scripts/e2e/visual-regression.cjs --mode=wsl-windows-edge --update",
    "test:visual:ui:linux": "node scripts/e2e/visual-regression.cjs --mode=linux-chromium",
    "test:visual:ui:update:linux": "node scripts/e2e/visual-regression.cjs --mode=linux-chromium --update"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.8.0",
    "@tauri-apps/plugin-autostart": "^2",
    "@tauri-apps/plugin-shell": "^2",
    "@tauri-apps/plugin-updater": "^2",
    "pinia": "^3.0.3",
    "vue": "^3.5.22",
    "vue-i18n": "^10.0.8"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@intlify/devtools-types": "^10.0.8",
    "@tailwindcss/postcss": "^4.2.2",
    "@tauri-apps/cli": "^2.8.2",
    "@types/node": "^24.5.2",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vitest/coverage-v8": "^3.2.4",
    "@vue/test-utils": "2.4.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "autoprefixer": "^10.4.27",
    "eslint": "^10.0.1",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.3.0",
    "jsdom": "^26.1.0",
    "postcss": "^8.5.8",
    "selenium-webdriver": "^4.41.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.56.0",
    "vite": "^7.1.5",
    "vitest": "^3.2.4",
    "vue-tsc": "^3.1.1"
  },
  "overrides": {
    "editorconfig": {
      "minimatch": "^9.0.6"
    }
  }
}
