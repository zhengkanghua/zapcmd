{
  "name": "zapcmd",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.7.0",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "version:sync": "node scripts/sync-version.mjs",
    "keys:sync": "node scripts/sync-keys.mjs",
    "prepare": "node scripts/setup-githooks.mjs",
    "tauri:dev": "npm run version:sync && npm run keys:sync && tauri dev",
    "tauri:build:debug": "npm run version:sync && npm run keys:sync && tauri build --debug --no-bundle",
    "tauri:build": "npm run version:sync && npm run keys:sync && tauri build --bundles msi",
    "tauri:build:all": "npm run version:sync && npm run keys:sync && tauri build",
    "e2e:desktop:smoke": "npm run tauri:build:debug && node scripts/e2e/desktop-smoke.cjs",
    "check:rust": "cargo check --manifest-path src-tauri/Cargo.toml",
    "lint": "eslint src vite.config.ts vitest.config.ts --ext .ts,.vue --max-warnings=0",
    "lint:fix": "eslint src vite.config.ts vitest.config.ts --ext .ts,.vue --fix",
    "check:all": "npm run version:sync && npm run lint && npm run typecheck && npm run typecheck:test && npm run test:coverage && npm run build && npm run check:rust",
    "precommit:guard": "node scripts/precommit-guard.mjs",
    "typecheck": "vue-tsc --noEmit",
    "typecheck:test": "vue-tsc --noEmit -p tsconfig.test.json",
    "test": "vitest",
    "test:related": "vitest related --run",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.8.0",
    "@tauri-apps/plugin-autostart": "^2",
    "@tauri-apps/plugin-shell": "^2",
    "@tauri-apps/plugin-updater": "^2",
    "pinia": "^3.0.3",
    "vue": "^3.5.22",
    "vue-i18n": "^10.0.8"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@intlify/devtools-types": "^10.0.8",
    "@tauri-apps/cli": "^2.8.2",
    "@types/node": "^24.5.2",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vitest/coverage-v8": "^3.2.4",
    "@vue/test-utils": "2.4.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^10.0.1",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.3.0",
    "jsdom": "^26.1.0",
    "postcss": "^8.5.6",
    "selenium-webdriver": "^4.41.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.56.0",
    "vite": "^7.1.5",
    "vitest": "^3.2.4",
    "vue-tsc": "^3.1.1"
  },
  "overrides": {
    "editorconfig": {
      "minimatch": "^9.0.6"
    }
  }
}
