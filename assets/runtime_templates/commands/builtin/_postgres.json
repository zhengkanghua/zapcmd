        "cli",
        "入口",
        "控制台"
      ],
      "category": "postgres",
      "platform": "all",
      "exec": {
        "program": "psql",
        "args": [
          "-h",
          "{{host}}",
          "-p",
          "{{port}}",
          "-U",
          "{{user}}",
          "-d",
          "{{database}}"
        ]
      },
      "adminRequired": false,
      "args": [
        {
          "key": "host",
          "type": "text",
          "required": true,
          "default": "127.0.0.1",
          "label": {
            "zh": "host",
            "en": "Host"
          }
        },
        {
          "key": "port",
          "type": "number",
          "required": true,
          "default": "5432",
