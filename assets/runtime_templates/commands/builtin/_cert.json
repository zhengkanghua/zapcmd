{
  "_meta": {
    "name": {
      "zh": "证书与 OpenSSL",
      "en": "Certificates and OpenSSL"
    },
    "source": "builtin"
  },
  "commands": [
    {
      "id": "openssl-x509-text",
      "name": {
        "zh": "OpenSSL 查看证书全文",
        "en": "Show Certificate Details"
      },
      "tags": [
        "openssl",
        "cert",
        "certificate",
        "x509",
        "text",
        "证书",
        "详情",
        "查看",
        "show"
      ],
      "category": "cert",
      "platform": "all",
      "exec": {
        "program": "openssl",
        "args": [
          "x509",
          "-in",
          "\"{{file}}\"",
          "-text",
          "-noout"
        ]
      },
      "adminRequired": false,
      "args": [
        {
          "key": "file",
          "type": "path",
          "required": true,
          "label": {
            "zh": "file",
            "en": "File"
          }
        }
      ],
      "prerequisites": [
        {
          "id": "openssl",
          "type": "binary",
          "required": true,
          "check": "binary:openssl"
        }
      ]
    },
    {
      "id": "openssl-cert-dates",
      "name": {
        "zh": "OpenSSL 查看证书有效期",
        "en": "Show Certificate Validity Dates"
      },
      "tags": [
        "openssl",
        "cert",
        "certificate",
        "dates",
        "证书",
        "有效期",
        "查看",
        "show"
      ],
      "category": "cert",
      "platform": "all",
      "exec": {
        "program": "openssl",
        "args": [
          "x509",
          "-in",
          "\"{{file}}\"",
          "-dates",
          "-noout"
        ]
      },
      "adminRequired": false,
      "args": [
        {
          "key": "file",
          "type": "path",
          "required": true,
          "label": {
            "zh": "file",
            "en": "File"
          }
        }
      ],
      "prerequisites": [
        {
          "id": "openssl",
          "type": "binary",
          "required": true,
          "check": "binary:openssl"
        }
      ]
    },
    {
      "id": "openssl-cert-fingerprint",
      "name": {
        "zh": "OpenSSL 查看证书指纹",
        "en": "Show Certificate Fingerprint"
      },
      "tags": [
        "openssl",
        "cert",
        "certificate",
        "fingerprint",
        "sha256",
        "指纹",
        "查看",
        "show"
      ],
      "category": "cert",
      "platform": "all",
      "exec": {
        "program": "openssl",
        "args": [
          "x509",
          "-in",
          "\"{{file}}\"",
          "-fingerprint",
          "-sha256",
          "-noout"
        ]
      },
      "adminRequired": false,
      "args": [
        {
          "key": "file",
          "type": "path",
          "required": true,
          "label": {
            "zh": "file",
            "en": "File"
          }
        }
      ],
      "prerequisites": [
        {
          "id": "openssl",
          "type": "binary",
          "required": true,
          "check": "binary:openssl"
        }
      ]
    },
    {
      "id": "openssl-s-client",
      "name": {
        "zh": "OpenSSL 建立 TLS 连接",
        "en": "Open TLS Connection with OpenSSL"
      },
      "tags": [
        "openssl",
        "s_client",
        "tls",
        "ssl",
        "证书",
        "连接",
        "握手",
        "handshake"
      ],
      "category": "cert",
      "platform": "all",
      "exec": {
        "program": "openssl",
        "args": [
          "s_client",
          "-connect",
          "{{host}}:{{port}}",
          "-servername",
          "{{host}}"
        ]
      },
      "adminRequired": false,
      "args": [
        {
          "key": "host",
          "type": "text",
          "required": true,
          "label": {
            "zh": "host",
            "en": "Host"
          }
        },
        {
          "key": "port",
          "type": "number",
          "required": true,
          "default": "443",
          "validation": {
            "min": 1,
            "max": 65535
          },
          "label": {
            "zh": "port",
            "en": "Port"
          }
        }
      ],
      "prerequisites": [
        {
          "id": "openssl",
          "type": "binary",
          "required": true,
          "check": "binary:openssl"
        }
      ]
    },
    {
      "id": "openssl-pkey-text",
      "name": {
        "zh": "OpenSSL 查看密钥详情",
        "en": "Show Private Key Details"
      },
      "tags": [
        "openssl",
        "pkey",
        "key",
        "private",
        "公钥",
        "私钥",
        "详情",
        "查看",
        "show"
      ],
      "category": "cert",
      "platform": "all",
      "exec": {
        "program": "openssl",
        "args": [
          "pkey",
          "-in",
          "\"{{file}}\"",
          "-text",
          "-noout"
        ]
      },
      "adminRequired": false,
      "args": [
        {
          "key": "file",
          "type": "path",
          "required": true,
          "label": {
            "zh": "file",
            "en": "File"
          }
        }
      ],
      "prerequisites": [
        {
          "id": "openssl",
          "type": "binary",
          "required": true,
          "check": "binary:openssl"
        }
      ]
    }
  ]
}
