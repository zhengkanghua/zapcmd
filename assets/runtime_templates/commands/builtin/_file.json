        "find"
      ],
      "category": "file",
      "platform": "mac",
      "exec": {
        "program": "find",
        "args": [
          "{{path}}",
          "-name"
        ],
        "stdinArgKey": "pattern"
      },
      "adminRequired": false,
      "args": [
        {
          "key": "path",
          "label": "path",
          "type": "path",
          "required": true,
          "default": "."
