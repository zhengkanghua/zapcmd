        "en": "Set User Name and Email"
      },
      "tags": [
        "git",
        "版本控制",
        "配置",
        "config",
        "用户",
        "user"
      ],
      "category": "git",
      "platform": "all",
      "script": {
        "runner": "bash",
        "command": "git config --global user.name \"{{name}}\" && git config --global user.email \"{{email}}\""
      },
      "adminRequired": false,
      "args": [
