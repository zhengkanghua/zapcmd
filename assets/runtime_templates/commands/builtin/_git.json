          "key": "name",
          "type": "text",
          "required": true,
          "label": {
            "zh": "名称",
            "en": "Name"
          }
        },
        {
          "key": "email",
          "type": "text",
          "required": true,
          "label": {
            "zh": "邮箱",
            "en": "Email"
          }
        }
      ],
      "prerequisites": [
        {
          "id": "git",
          "type": "binary",
          "required": true,
          "check": "binary:git"
        },
        {
          "id": "bash",
          "type": "shell",
          "required": true,
          "check": "shell:bash"
        }
      ]
    }
  ]
