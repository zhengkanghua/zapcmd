      ],
      "category": "dev",
      "platform": "all",
      "script": {
        "runner": "bash",
        "command": "python3 -c \"import base64, json, sys; parts=sys.argv[1].split('.'); dec=lambda s: json.loads(base64.urlsafe_b64decode(s + '=' * (-len(s) % 4)).decode()); print(json.dumps({'header': dec(parts[0]), 'payload': dec(parts[1])}, ensure_ascii=False, indent=2))\" \"{{token}}\""
      },
      "adminRequired": false,
      "args": [
        {
          "key": "token",
          "type": "text",
          "required": true,
