      "id": "mysql-shell",
      "name": "MySQL Shell",
      "tags": [
        "mysql",
        "shell",
        "cli",
        "入口",
        "控制台"
      ],
      "category": "mysql",
      "platform": "all",
      "template": "mysql -h {{host}} -P {{port}} -u {{user}} -p",
      "adminRequired": false,
      "dangerous": false,
      "args": [
        {
          "key": "host",
          "label": "host",
          "type": "text",
          "required": true,
          "default": "127.0.0.1"
        },
        {
          "key": "port",
          "label": "port",
          "type": "number",
          "required": true,
          "default": "3306",
          "validation": {
            "min": 1,
            "max": 65535
          }
        },
        {
          "key": "user",
          "label": "user",
          "type": "text",
          "required": true,
          "default": "root"
        }
      ],
      "prerequisites": [
        {
          "id": "mysql",
          "type": "binary",
          "required": true,
          "check": "binary:mysql"
        }
