    {
      "id": "kubectl-port-forward",
      "name": {
        "zh": "kubectl 端口转发",
        "en": "Run kubectl Port Forward"
      },
      "tags": [
        "kubernetes",
        "kubectl",
        "port-forward",
        "resource",
        "namespace"
      ],
      "category": "kubernetes",
      "platform": "all",
      "exec": {
        "program": "kubectl",
        "args": [
          "port-forward",
          "{{resource}}",
          "{{localPort}}:{{remotePort}}",
          "-n",
          "{{namespace}}"
        ]
      },
      "adminRequired": false,
      "args": [
        {
          "key": "resource",
          "type": "text",
          "required": true,
          "default": "deployment/my-app",
          "label": {
            "zh": "resource",
            "en": "Resource"
          }
        },
        {
          "key": "localPort",
          "type": "number",
          "required": true,
          "default": "8080",
          "validation": {
            "min": 1,
            "max": 65535
          },
          "label": {
            "zh": "localPort",
            "en": "Local Port"
          }
        },
        {
          "key": "remotePort",
          "type": "number",
          "required": true,
          "default": "80",
          "validation": {
            "min": 1,
            "max": 65535
          },
          "label": {
            "zh": "remotePort",
            "en": "Remote Port"
          }
        },
        {
          "key": "namespace",
          "type": "text",
          "required": true,
          "default": "default",
          "label": {
            "zh": "namespace",
            "en": "Namespace"
          }
        }
      ],
      "prerequisites": [
        {
          "id": "kubectl",
          "type": "binary",
          "required": true,
          "check": "binary:kubectl"
        }
      ]
    },
