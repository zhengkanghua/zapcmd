{
  "_meta": {
    "name": {
      "zh": "SSH 与远程连接",
      "en": "SSH and Remote Connections"
    },
    "source": "builtin"
  },
  "commands": [
    {
      "id": "ssh-connect",
      "name": {
        "zh": "SSH 连接",
        "en": "Connect via SSH"
      },
      "tags": [
        "ssh",
        "远程",
        "连接",
        "connect"
      ],
      "category": "ssh",
      "platform": "all",
      "exec": {
        "program": "ssh",
        "args": [
          "{{user}}@{{host}}"
        ]
      },
      "adminRequired": false,
      "args": [
        {
          "key": "user",
          "type": "text",
          "required": true,
          "label": {
            "zh": "user",
            "en": "User"
          }
        },
        {
          "key": "host",
          "type": "text",
          "required": true,
          "label": {
            "zh": "host",
            "en": "Host"
          }
        }
      ],
      "prerequisites": [
        {
          "id": "ssh",
          "type": "binary",
          "required": true,
          "check": "binary:ssh"
        }
      ]
    },
    {
      "id": "ssh-connect-port",
      "name": {
        "zh": "SSH 连接 (指定端口)",
        "en": "Connect via SSH on Custom Port"
      },
      "tags": [
        "ssh",
        "远程",
        "连接",
        "connect",
        "端口",
        "port"
      ],
      "category": "ssh",
      "platform": "all",
      "exec": {
        "program": "ssh",
        "args": [
          "-p",
          "{{port}}",
          "{{user}}@{{host}}"
        ]
      },
      "adminRequired": false,
      "args": [
        {
          "key": "user",
          "type": "text",
          "required": true,
          "label": {
            "zh": "user",
            "en": "User"
          }
        },
        {
          "key": "host",
          "type": "text",
          "required": true,
          "label": {
            "zh": "host",
            "en": "Host"
          }
        },
        {
          "key": "port",
          "type": "number",
          "required": true,
          "validation": {
            "min": 1,
            "max": 65535
          },
          "label": {
            "zh": "port",
            "en": "Port"
          }
        }
      ],
      "prerequisites": [
        {
          "id": "ssh",
          "type": "binary",
          "required": true,
          "check": "binary:ssh"
        }
      ]
    },
    {
      "id": "ssh-connect-key",
      "name": {
        "zh": "SSH 连接 (密钥)",
        "en": "Connect via SSH with Key"
      },
      "tags": [
        "ssh",
        "远程",
        "连接",
        "connect",
        "密钥",
        "key"
      ],
      "category": "ssh",
      "platform": "all",
      "exec": {
        "program": "ssh",
        "args": [
          "-i",
          "{{key}}",
          "{{user}}@{{host}}"
        ]
      },
      "adminRequired": false,
      "args": [
        {
          "key": "key",
          "type": "path",
          "required": true,
          "label": {
            "zh": "key",
            "en": "Key"
          }
        },
        {
          "key": "user",
          "type": "text",
          "required": true,
          "label": {
            "zh": "user",
            "en": "User"
          }
        },
        {
          "key": "host",
          "type": "text",
          "required": true,
          "label": {
            "zh": "host",
            "en": "Host"
          }
        }
      ],
      "prerequisites": [
        {
          "id": "ssh",
          "type": "binary",
          "required": true,
          "check": "binary:ssh"
        }
      ]
    },
    {
      "id": "scp-upload",
      "name": {
        "zh": "SCP 上传文件",
        "en": "Upload File via SCP"
      },
      "tags": [
        "ssh",
        "远程",
        "scp",
        "upload",
        "上传",
        "文件",
        "file"
      ],
      "category": "ssh",
      "platform": "all",
      "exec": {
        "program": "scp",
        "args": [
          "{{local}}",
          "{{user}}@{{host}}:{{remote}}"
        ]
      },
      "adminRequired": false,
      "args": [
        {
          "key": "local",
          "type": "path",
          "required": true,
          "label": {
            "zh": "local",
            "en": "Local Path"
          }
        },
        {
          "key": "user",
          "type": "text",
          "required": true,
          "label": {
            "zh": "user",
            "en": "User"
          }
        },
        {
          "key": "host",
          "type": "text",
          "required": true,
          "label": {
            "zh": "host",
            "en": "Host"
          }
        },
        {
          "key": "remote",
          "type": "text",
          "required": true,
          "label": {
            "zh": "remote",
            "en": "Remote Path"
          }
        }
      ],
      "prerequisites": [
        {
          "id": "scp",
          "type": "binary",
          "required": true,
          "check": "binary:scp"
        }
      ]
    },
    {
      "id": "scp-download",
      "name": {
        "zh": "SCP 下载文件",
        "en": "Download File via SCP"
      },
      "tags": [
        "ssh",
        "远程",
        "scp",
        "下载",
        "download",
        "文件",
        "file"
      ],
      "category": "ssh",
      "platform": "all",
      "exec": {
        "program": "scp",
        "args": [
          "{{user}}@{{host}}:{{remote}}",
          "{{local}}"
        ]
      },
      "adminRequired": false,
      "args": [
        {
          "key": "user",
          "type": "text",
          "required": true,
          "label": {
            "zh": "user",
            "en": "User"
          }
        },
        {
          "key": "host",
          "type": "text",
          "required": true,
          "label": {
            "zh": "host",
            "en": "Host"
          }
        },
        {
          "key": "remote",
          "type": "text",
          "required": true,
          "label": {
            "zh": "remote",
            "en": "Remote Path"
          }
        },
        {
          "key": "local",
          "type": "path",
          "required": true,
          "label": {
            "zh": "local",
            "en": "Local Path"
          }
        }
      ],
      "prerequisites": [
        {
          "id": "scp",
          "type": "binary",
          "required": true,
          "check": "binary:scp"
        }
      ]
    },
    {
      "id": "ssh-keygen",
      "name": {
        "zh": "生成 SSH 密钥",
        "en": "Generate SSH Key"
      },
      "tags": [
        "ssh",
        "远程",
        "生成密钥",
        "keygen",
        "密钥",
        "key"
      ],
      "category": "ssh",
      "platform": "all",
      "exec": {
        "program": "ssh-keygen",
        "args": [
          "-t",
          "ed25519",
          "-C",
          "\"{{email}}\""
        ]
      },
      "adminRequired": false,
      "args": [
        {
          "key": "email",
          "type": "text",
          "required": true,
          "label": {
            "zh": "email",
            "en": "Email"
          }
        }
      ],
      "prerequisites": [
        {
          "id": "ssh-keygen",
          "type": "binary",
          "required": true,
          "check": "binary:ssh-keygen"
        }
      ]
    },
    {
      "id": "ssh-copy-id-mac",
      "name": {
        "zh": "复制公钥到服务器",
        "en": "Copy Public Key to Server"
      },
      "tags": [
        "ssh",
        "远程",
        "copy",
        "id"
      ],
      "category": "ssh",
      "platform": "mac",
      "exec": {
        "program": "ssh-copy-id",
        "args": [
          "{{user}}@{{host}}"
        ]
      },
      "adminRequired": false,
      "args": [
        {
          "key": "user",
          "type": "text",
          "required": true,
          "label": {
            "zh": "user",
            "en": "User"
          }
        },
        {
          "key": "host",
          "type": "text",
          "required": true,
          "label": {
            "zh": "host",
            "en": "Host"
          }
        }
      ],
      "prerequisites": [
        {
          "id": "ssh-copy-id",
          "type": "binary",
          "required": true,
          "check": "binary:ssh-copy-id"
        }
      ]
    },
    {
      "id": "ssh-copy-id-linux",
      "name": {
        "zh": "复制公钥到服务器",
        "en": "Copy Public Key to Server"
      },
      "tags": [
        "ssh",
        "远程",
        "copy",
        "id"
      ],
      "category": "ssh",
      "platform": "linux",
      "exec": {
        "program": "ssh-copy-id",
        "args": [
          "{{user}}@{{host}}"
        ]
      },
      "adminRequired": false,
      "args": [
        {
          "key": "user",
          "type": "text",
          "required": true,
          "label": {
            "zh": "user",
            "en": "User"
          }
        },
        {
          "key": "host",
          "type": "text",
          "required": true,
          "label": {
            "zh": "host",
            "en": "Host"
          }
        }
      ],
      "prerequisites": [
        {
          "id": "ssh-copy-id",
          "type": "binary",
          "required": true,
          "check": "binary:ssh-copy-id"
        }
      ]
    },
    {
      "id": "ssh-tunnel",
      "name": {
        "zh": "SSH 隧道 (端口转发)",
        "en": "Create SSH Tunnel (Port Forwarding)"
      },
      "tags": [
        "ssh",
        "远程",
        "隧道",
        "tunnel",
        "端口",
        "port"
      ],
      "category": "ssh",
      "platform": "all",
      "exec": {
        "program": "ssh",
        "args": [
          "-L",
          "{{local_port}}:{{target_host}}:{{target_port}}",
          "{{user}}@{{host}}"
        ]
      },
      "adminRequired": false,
      "args": [
        {
          "key": "local_port",
          "type": "number",
          "required": true,
          "validation": {
            "min": 1,
            "max": 65535
          },
          "label": {
            "zh": "local_port",
            "en": "Local Port"
          }
        },
        {
          "key": "target_host",
          "type": "text",
          "required": true,
          "label": {
            "zh": "target_host",
            "en": "Target Host"
          }
        },
        {
          "key": "target_port",
          "type": "number",
          "required": true,
          "validation": {
            "min": 1,
            "max": 65535
          },
          "label": {
            "zh": "target_port",
            "en": "Target Port"
          }
        },
        {
          "key": "user",
          "type": "text",
          "required": true,
          "label": {
            "zh": "user",
            "en": "User"
          }
        },
        {
          "key": "host",
          "type": "text",
          "required": true,
          "label": {
            "zh": "host",
            "en": "Host"
          }
        }
      ],
      "prerequisites": [
        {
          "id": "ssh",
          "type": "binary",
          "required": true,
          "check": "binary:ssh"
        }
      ]
    },
    {
      "id": "ssh-config-list",
      "name": {
        "zh": "查看 SSH 配置",
        "en": "Show SSH Configuration"
      },
      "tags": [
        "ssh",
        "远程",
        "配置",
        "config",
        "列表",
        "list",
        "查看",
        "show"
      ],
      "category": "ssh",
      "platform": "all",
      "exec": {
        "program": "cat",
        "args": [
          "~/.ssh/config"
        ]
      },
      "adminRequired": false
    },
    {
      "id": "ssh-agent-add",
      "name": {
        "zh": "添加密钥到 Agent",
        "en": "Add Key to SSH Agent"
      },
      "tags": [
        "ssh",
        "远程",
        "agent",
        "添加",
        "add",
        "密钥",
        "key"
      ],
      "category": "ssh",
      "platform": "all",
      "exec": {
        "program": "ssh-add",
        "args": [
          "{{key}}"
        ]
      },
      "adminRequired": false,
      "args": [
        {
          "key": "key",
          "type": "path",
          "required": true,
          "default": "~/.ssh/id_ed25519",
          "label": {
            "zh": "key",
            "en": "Key"
          }
        }
      ],
      "prerequisites": [
        {
          "id": "ssh-add",
          "type": "binary",
          "required": true,
          "check": "binary:ssh-add"
        }
      ]
    }
  ]
}
