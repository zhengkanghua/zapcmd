{
  "_meta": {
    "name": "Service 服务管理",
    "author": "zapcmd-team",
    "version": "1.0.0",
    "description": "Generated from docs/command_sources",
    "source": "docs/command_sources/_service.md"
  },
  "commands": [
    {
      "id": "service-status-win",
      "name": "查看 Windows 服务状态",
      "tags": [
        "service",
        "服务",
        "windows",
        "win",
        "status",
        "状态",
        "查看",
        "show"
      ],
      "category": "service",
      "platform": "win",
      "template": "Get-Service -Name \"{{name}}\"",
      "adminRequired": false,
      "dangerous": false,
      "args": [
        {
          "key": "name",
          "label": "name",
          "type": "text",
          "required": true
        }
      ],
      "prerequisites": [
        {
          "id": "powershell",
          "type": "shell",
          "required": true,
          "check": "shell:powershell"
        }
      ]
    },
    {
      "id": "service-list-running-win",
      "name": "列出运行中的 Windows 服务",
      "tags": [
        "service",
        "服务",
        "windows",
        "win",
        "list",
        "running",
        "运行",
        "列表"
      ],
      "category": "service",
      "platform": "win",
      "template": "Get-Service | Where-Object {$_.Status -eq 'Running'} | Sort-Object DisplayName",
      "adminRequired": false,
      "dangerous": false,
      "prerequisites": [
        {
          "id": "powershell",
          "type": "shell",
          "required": true,
          "check": "shell:powershell"
        }
      ]
    },
    {
      "id": "service-status-linux",
      "name": "查看 Linux 服务状态",
      "tags": [
        "service",
        "服务",
        "linux",
        "status",
        "状态",
        "查看",
        "show"
      ],
      "category": "service",
      "platform": "linux",
      "template": "systemctl status {{name}} --no-pager",
      "adminRequired": false,
      "dangerous": false,
      "args": [
        {
          "key": "name",
          "label": "name",
          "type": "text",
          "required": true
        }
      ],
      "prerequisites": [
        {
          "id": "systemctl",
          "type": "binary",
          "required": true,
          "check": "binary:systemctl"
        }
      ]
    },
    {
      "id": "service-list-running-linux",
      "name": "列出运行中的 Linux 服务",
      "tags": [
        "service",
        "服务",
        "linux",
        "list",
        "running",
        "运行",
        "列表"
      ],
      "category": "service",
      "platform": "linux",
      "template": "systemctl list-units --type=service --state=running --no-pager",
      "adminRequired": false,
      "dangerous": false,
      "prerequisites": [
        {
          "id": "systemctl",
          "type": "binary",
          "required": true,
          "check": "binary:systemctl"
        }
      ]
    },
    {
      "id": "service-logs-linux",
      "name": "查看 Linux 服务日志",
      "tags": [
        "service",
        "服务",
        "linux",
        "logs",
        "日志",
        "journalctl",
        "查看",
        "show"
      ],
      "category": "service",
      "platform": "linux",
      "template": "journalctl -u {{name}} -n {{lines}} --no-pager",
      "adminRequired": false,
      "dangerous": false,
      "args": [
        {
          "key": "name",
          "label": "name",
          "type": "text",
          "required": true
        },
        {
          "key": "lines",
          "label": "lines",
          "type": "number",
          "required": true,
          "default": "100",
          "validation": {
            "min": 1,
            "max": 10000
          }
        }
      ],
      "prerequisites": [
        {
          "id": "journalctl",
          "type": "binary",
          "required": true,
          "check": "binary:journalctl"
        }
      ]
    }
  ]
}
