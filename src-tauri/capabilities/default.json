{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for the main window",
  "windows": ["main", "settings"],
  "permissions": ["core:default", "core:window:allow-close", "core:window:allow-toggle-maximize", "core:window:allow-minimize", "core:window:allow-is-maximized", "updater:default"]
}
