{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "ZapCmd",
  "version": "1.0.0",
  "identifier": "com.zapcmd.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ZapCmd",
        "label": "main",
        "width": 680,
        "height": 124,
        "center": true,
        "visible": true,
        "skipTaskbar": true,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "alwaysOnTop": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ipc: http://ipc.localhost https://ipc.localhost https://github.com https://*.github.com https://*.githubusercontent.com; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: data: blob:; font-src 'self' data:; media-src 'self' asset: data: blob:; object-src 'none'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/zhengkanghua/zapcmd/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDZCNDAyNkFDQzdGQjk4QTEKUldTaG1QdkhyQ1pBYXhodWlrdU5lc2RkbXQ2azJGUDNMS1VJUEoya2Qrak5zNjV4U1UzMk1lUzcK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
